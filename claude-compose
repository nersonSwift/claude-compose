#!/usr/bin/env bash
set -euo pipefail

# claude-compose — Multi-project Claude Code launcher
# Merges MCP servers, skills, and permissions from external projects
# into a single Claude Code session.

VERSION="1.1.1"

# ── Globals ──────────────────────────────────────────────────────────
CONFIG_FILE=""
DRY_RUN=false
EXTRA_ARGS=()
ORIGINAL_CWD="$(pwd)"
SESSION_DIR=""
MERGED_MCP="{}"
MERGED_PERMISSIONS="[]"
SKILLS_TO_COPY=()  # pairs: "src_dir|dest_name"
AGENTS_TO_COPY=()  # pairs: "src_file|dest_name"
CLAUDE_ARGS=()
NEED_CLAUDE_MD_ENV=false
SESSION_ID="$$"  # PID for temp session naming (config command)
SUBCOMMAND=""       # "", "config"
CONFIG_YES=false    # -y flag for config
CONFIG_PATH=""      # optional path for config -y
CONFIG_CHECK=false  # --check flag for config
PRESETS_DIR="$HOME/.claude-compose/presets"   # global presets directory
PROCESSED_PRESETS=()                         # cycle detection set

# ── Colors ───────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Usage ────────────────────────────────────────────────────────────
usage() {
    echo -e "${BOLD}claude-compose${NC} v${VERSION} — Multi-project Claude Code launcher"
    echo ""
    echo -e "${BOLD}Usage:${NC}"
    echo "  claude-compose [options] [-- claude-args...]"
    echo "  claude-compose config [-y <path>] [--check] [-f <file>]"
    echo ""
    echo -e "${BOLD}Commands:${NC}"
    echo "  config        Create or manage config (via Claude, or -y for quick create)"
    echo ""
    echo -e "${BOLD}Options:${NC}"
    echo "  -f <file>     Config file (default: claude-compose.json)"
    echo "  -y, --yes     Skip prompts, use defaults (config only)"
    echo "  --check       Validate config via dry-run (config only)"
    echo "  --dry-run     Show what would be launched without executing"
    echo "  -h, --help    Show this help"
    echo "  -v, --version Show version"
    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo "  claude-compose                          # Use claude-compose.json"
    echo "  claude-compose config                   # Create or edit config via Claude"
    echo "  claude-compose config -y ~/Code/app     # Quick create with defaults"
    echo "  claude-compose config --check           # Validate config"
    echo "  claude-compose -f compose-full.json     # Custom config"
    echo "  claude-compose --dry-run                # Preview mode"
    echo "  claude-compose -- -p \"explain arch\"     # Pass args to claude"
}

# ── Session directory ───────────────────────────────────────────────

# Stable session dir for normal launches (persists for --resume)
create_session_dir() {
    local config_hash
    config_hash=$(printf '%s' "$CONFIG_FILE" | md5sum 2>/dev/null | cut -d' ' -f1 \
        || printf '%s' "$CONFIG_FILE" | md5 -q 2>/dev/null \
        || printf '%s' "$CONFIG_FILE" | shasum -a 256 | cut -c1-32)
    SESSION_DIR="$HOME/.claude-compose/sessions/${config_hash}"
    mkdir -p "$SESSION_DIR/.claude/agents"
    mkdir -p "$SESSION_DIR/.claude/skills"
}

# Temp session dir for config command (cleaned up on exit)
create_temp_session_dir() {
    SESSION_DIR="${TMPDIR:-/tmp}/claude-compose-${SESSION_ID}"
    mkdir -p "$SESSION_DIR/.claude/agents"
    mkdir -p "$SESSION_DIR/.claude/skills"
}

# Compute hash of config file content
config_content_hash() {
    if command -v md5sum &>/dev/null; then
        md5sum "$CONFIG_FILE" | cut -d' ' -f1
    elif command -v md5 &>/dev/null; then
        md5 -q "$CONFIG_FILE"
    else
        shasum -a 256 "$CONFIG_FILE" | cut -c1-32
    fi
}

# Clean compose-generated files before regenerating (preserves Claude session data)
clean_compose_files() {
    rm -rf "$SESSION_DIR/.claude/agents"/*
    rm -rf "$SESSION_DIR/.claude/skills"/*
    rm -f "$SESSION_DIR/.mcp.json"
    rm -f "$SESSION_DIR/.claude/settings.local.json"
}

# Register this session's PID, save config content hash, GC dead PIDs
register_session() {
    local content_hash
    content_hash=$(config_content_hash)
    echo "$content_hash" > "$SESSION_DIR/.compose-hash"

    # GC dead PIDs and add our own
    local live_pids
    live_pids=$(get_live_session_pids)
    { [[ -n "$live_pids" ]] && echo "$live_pids"; echo "$SESSION_ID"; } > "$SESSION_DIR/.compose-pids"
}

# Remove this session's PID on exit
unregister_session() {
    if [[ -n "$SESSION_DIR" && -f "$SESSION_DIR/.compose-pids" ]]; then
        local remaining
        remaining=$(grep -v "^${SESSION_ID}$" "$SESSION_DIR/.compose-pids" 2>/dev/null | grep -v '^$' || true)
        if [[ -n "$remaining" ]]; then
            echo "$remaining" > "$SESSION_DIR/.compose-pids"
        else
            : > "$SESSION_DIR/.compose-pids"
        fi
    fi
}

# Get list of still-alive PIDs from session dir
get_live_session_pids() {
    [[ -f "$SESSION_DIR/.compose-pids" ]] || return 0
    while IFS= read -r pid; do
        [[ -z "$pid" ]] && continue
        if kill -0 "$pid" 2>/dev/null; then
            echo "$pid"
        fi
    done < "$SESSION_DIR/.compose-pids"
}

# Check session state and decide whether to clean/regenerate
# Returns: 0 = proceed, 1 = user aborted
check_session_state() {
    local current_hash live_pids stored_hash

    # Fresh session dir — no hash yet
    if [[ ! -f "$SESSION_DIR/.compose-hash" ]]; then
        clean_compose_files
        return 0
    fi

    current_hash=$(config_content_hash)
    stored_hash=$(cat "$SESSION_DIR/.compose-hash")
    live_pids=$(get_live_session_pids)

    if [[ "$current_hash" != "$stored_hash" && -n "$live_pids" ]]; then
        # Config changed with active sessions — warn
        echo -e "${YELLOW}Warning: Config has changed since the last launch, but there are active sessions:${NC}" >&2
        echo "$live_pids" | while read -r pid; do
            echo -e "  PID: $pid" >&2
        done
        echo "" >&2
        echo -n "Overwrite session files? Active sessions may be affected. [y/N] " >&2
        local reply
        read -r reply < /dev/tty
        if [[ "$reply" != [yY] ]]; then
            echo -e "${RED}Aborted.${NC}" >&2
            return 1
        fi
    fi

    # Always clean and regenerate — project contents may have changed
    clean_compose_files
    return 0
}

# Remove temp session dir entirely (config command only)
cleanup_temp_session() {
    if [[ -n "$SESSION_DIR" && -d "$SESSION_DIR" ]]; then
        rm -rf "$SESSION_DIR"
    fi
}

# ── Session settings ────────────────────────────────────────────────
write_session_settings() {
    local settings_file="$SESSION_DIR/.claude/settings.local.json"
    local deny_rules
    deny_rules=$(jq -n --arg dir "$SESSION_DIR" '[
        ("Edit(" + $dir + "/**)"),
        ("Write(" + $dir + "/**)")
    ]')

    if [[ $(echo "$MERGED_PERMISSIONS" | jq 'length') -gt 0 ]]; then
        jq -n \
            --argjson allow "$MERGED_PERMISSIONS" \
            --argjson deny "$deny_rules" \
            '{permissions: {allow: $allow, deny: $deny}}' \
            > "$settings_file"
    else
        jq -n \
            --argjson deny "$deny_rules" \
            '{permissions: {deny: $deny}}' \
            > "$settings_file"
    fi
}

# ── Compose management skill ─────────────────────────────────────────
# Write compose-config skill for this session
write_compose_skills() {
    local config_file="$1"
    local skill_dir="$SESSION_DIR/.claude/skills/compose-config"
    mkdir -p "$skill_dir"

    cat > "$skill_dir/SKILL.md" << 'SKILLCONFIG'
---
name: compose-config
description: Create or manage a claude-compose.json configuration. Use when the user runs /compose-config or needs to create, edit, or review their claude-compose config.
---

# compose-config — Create or manage claude-compose config

Config file: `__CONFIG_FILE__`__CONFIG_DEFAULT__

## Multiple config files

A project can have several config files for different scenarios (e.g., `claude-compose.json` for daily work, `compose-full.json` with all projects). The default file is `claude-compose.json` — it's used when running `claude-compose` without `-f`. Additional configs are used via:

```
claude-compose -f compose-full.json
```

After finishing, if the user wants to create another config for a different scenario, suggest:

```
claude-compose config -f <other-name>.json
```

## Config schema

Top-level fields:

| Field | Type | Default | Description |
|-------|------|---------|-------------|
| \`include_root\` | boolean | \`true\` | Add the launch directory as --add-dir for file access |
| \`projects\` | array | \`[]\` | List of external projects to merge |
| \`presets\` | string[] | \`[]\` | Preset names to activate |

Each project in the \`projects\` array can have these fields:

| Field | Type | Default | Description |
|-------|------|---------|-------------|
| `path` | string | **required** | Path to external project directory |
| `mcp.include` | string[] | `["*"]` | Glob patterns for MCP servers to include |
| `mcp.exclude` | string[] | `[]` | Glob patterns for MCP servers to exclude |
| `mcp.rename` | object | `{}` | Rename MCP servers: `{"old-name": "new-name"}` |
| `permissions.include` | string[] | `["*"]` | Patterns for permissions to include |
| `permissions.exclude` | string[] | `[]` | Patterns for permissions to exclude |
| `agents.include` | string[] | `["*"]` | Glob patterns for agents to include |
| `agents.exclude` | string[] | `[]` | Glob patterns for agents to exclude |
| `agents.rename` | object | `{}` | Rename agents: `{"old-name": "new-name"}` |
| `claude_md` | boolean | `true` | Load CLAUDE.md from project |
| `files` | boolean | `true` | Add project dir for file access via --add-dir |

## Presets

Presets are reusable sets of Claude resources stored globally at \`~/.claude-compose/presets/<name>/\`.

### Preset directory structure

A preset directory can contain (all optional):
- \`.mcp.json\` — MCP server configs
- \`.claude/agents/*.md\` — agent definitions
- \`.claude/skills/*/\` — skill definitions
- \`.claude/settings.local.json\` — permissions
- \`CLAUDE.md\` — instructions
- \`preset.json\` — config with filter settings, nested presets, and projects

### preset.json schema

| Field | Type | Default | Description |
|-------|------|---------|-------------|
| \`mcp.include\` | string[] | \`["*"]\` | Glob patterns for MCP servers to include |
| \`mcp.exclude\` | string[] | \`[]\` | Glob patterns for MCP servers to exclude |
| \`mcp.rename\` | object | \`{}\` | Rename MCP servers |
| \`permissions.include\` | string[] | \`["*"]\` | Patterns for permissions to include |
| \`permissions.exclude\` | string[] | \`[]\` | Patterns for permissions to exclude |
| \`agents.include\` | string[] | \`["*"]\` | Glob patterns for agents to include |
| \`agents.exclude\` | string[] | \`[]\` | Glob patterns for agents to exclude |
| \`agents.rename\` | object | \`{}\` | Rename agents |
| \`skills.include\` | string[] | \`["*"]\` | Glob patterns for skills to include |
| \`skills.exclude\` | string[] | \`[]\` | Glob patterns for skills to exclude |
| \`claude_md\` | boolean | \`true\` | Load CLAUDE.md from preset |
| \`files\` | boolean | \`false\` | Add preset dir for file access |
| \`presets\` | string[] | \`[]\` | Nested preset names (recursive) |
| \`projects\` | array | \`[]\` | External projects (same format as claude-compose.json projects) |

### Referencing presets from config

Add to claude-compose.json:
\`\`\`json
{
  "presets": ["my-preset"],
  "projects": [...]
}
\`\`\`

### Preset management operations

- **Create preset**: Copy Claude files (\`.mcp.json\`, \`.claude/\`, \`CLAUDE.md\`) from a user-specified project path into \`~/.claude-compose/presets/<name>/\`, optionally create \`preset.json\`
- **List presets**: Scan \`~/.claude-compose/presets/\` and show contents summary
- **Delete preset**: Remove the preset directory
- **Edit preset**: Modify files or \`preset.json\` in the preset directory

### Priority order

Presets are processed before projects. On name conflicts, later entries overwrite earlier ones:
1. Preset's own resources (lowest priority)
2. Nested presets
3. Preset's projects
4. Top-level projects from claude-compose.json (highest priority)

## Simplification rules — IMPORTANT

When writing config, **omit any field that equals its default**:
- `include_root: true` → omit (top-level)
- `mcp.include: ["*"]` → omit
- `mcp.exclude: []` → omit
- `mcp.rename: {}` → omit
- Empty `mcp` object after removals → omit entirely
- Same for `permissions` and `agents` sections
- `claude_md: true` → omit
- `files: true` → omit

A project with all defaults is just `{"path": "~/path"}`.

## Mode detection

Check if `__CONFIG_FILE__` exists:
- **File does not exist** → **Create mode**
- **File exists** → **Edit mode**

## Create mode

1. **Ask** for project paths. For each path:
   a. Verify directory exists (warn if not, but allow — user may set up later)
   b. Reject if a project path resolves to the session directory (the current working directory) or to \`__ORIGINAL_CWD__\`
   c. **Scan resources**:
      - Read `<path>/.mcp.json` → show server names from `.mcpServers` keys
      - Read `<path>/.claude/settings.local.json` → show permissions from `.permissions.allow[]`
      - List `<path>/.claude/agents/*.md` → show agent names (filename without .md)
   d. Show discovered resources to the user
   e. Ask if they want defaults (include everything) or customize filtering
   f. If customizing — ask about each relevant section

2. Ask if user wants to add another project or finish.

3. **Write config** using bash + jq for proper JSON formatting:
   ```bash
   tmp=$(mktemp "__CONFIG_FILE__.XXXXXX")
   echo '<json>' | jq '.' > "$tmp" && mv "$tmp" "__CONFIG_FILE__"
   ```
   Apply simplification rules before writing.

4. **Show summary**: number of projects, key settings for each.

## Edit mode

1. **Read** `__CONFIG_FILE__` and show a summary of all projects:
   - Path
   - MCP settings (include/exclude/rename, or "defaults" if none set)
   - Permissions settings (include/exclude, or "defaults")
   - Agents settings (include/exclude/rename, or "defaults")
   - claude_md and files toggles (only show if non-default)

2. **Ask** what to do:
   - **Add** a new project
   - **Edit** an existing project
   - **Remove** a project
   - **Manage presets** — create, list, delete, or edit presets
   - **Done** — finish

3. **Add**: Follow the same flow as create mode (scan, ask, append).

4. **Edit**:
   a. Let user pick which project (by number or path)
   b. Show current settings + scan project dir for available resources
   c. Let user modify any section: MCP (include/exclude/rename), permissions (include/exclude), agents (include/exclude/rename), claude_md toggle, files toggle
   d. Apply simplification rules

5. **Remove**: Confirm with user, then delete from array.

6. After each operation, show updated config state and ask for next action.

7. **Write** changes atomically:
   ```bash
   tmp=$(mktemp "__CONFIG_FILE__.XXXXXX")
   echo '<json>' | jq '.' > "$tmp" && mv "$tmp" "__CONFIG_FILE__"
   ```

## Validation

After writing config (in either mode), run validation and show results:

```bash
cd __ORIGINAL_CWD__ && claude-compose --dry-run__CONFIG_F_FLAG__
```

Show the dry-run output to the user so they can verify what would be launched.

## After finishing

Show the user how to launch and manage:

```
Ready to launch:
  cd __ORIGINAL_CWD__ && claude-compose__CONFIG_F_FLAG__

Validate:
  cd __ORIGINAL_CWD__ && claude-compose config --check__CONFIG_F_FLAG__

Create another config for a different scenario:
  cd __ORIGINAL_CWD__ && claude-compose config -f <name>.json
```

If running inside an existing claude-compose session, recommend starting a new session for changes to take effect.

## Rules
- Keep `~` in paths as-is (claude-compose expands at runtime)
- Glob patterns: `*` matches everything, `prefix-*` matches by prefix
- Always validate JSON with `jq` before writing
- Reject project paths that resolve to the current working directory or to `__ORIGINAL_CWD__`
- Do NOT create the config if user adds zero projects (create mode)
- Do NOT modify or delete the config if user made no changes (edit mode)
- When showing current state, read the file fresh each time (edit mode)
