# ── Glob matching ────────────────────────────────────────────────────
# Returns 0 if $1 matches any pattern in the include list AND
# does not match any pattern in the exclude list.
# $1 = name, $2 = include JSON array, $3 = exclude JSON array
matches_filter() {
    local name="$1"
    local include_json="$2"
    local exclude_json="$3"

    # Parse include patterns
    local include_count
    include_count=$(echo "$include_json" | jq -r 'length')

    if [[ "$include_count" -eq 0 ]]; then
        return 1  # empty include = nothing included
    fi

    # Check include
    local included=false
    for i in $(seq 0 $((include_count - 1))); do
        local pattern
        pattern=$(echo "$include_json" | jq -r ".[$i]")
        # shellcheck disable=SC2053
        if [[ "$name" == $pattern ]]; then
            included=true
            break
        fi
    done

    if [[ "$included" == false ]]; then
        return 1
    fi

    # Check exclude
    local exclude_count
    exclude_count=$(echo "$exclude_json" | jq -r 'length')

    for i in $(seq 0 $((exclude_count - 1))); do
        local pattern
        pattern=$(echo "$exclude_json" | jq -r ".[$i]")
        # shellcheck disable=SC2053
        if [[ "$name" == $pattern ]]; then
            return 1  # excluded
        fi
    done

    return 0
}


# ── Parse CLI args ───────────────────────────────────────────────────
parse_args() {
    # Detect subcommand as first positional argument
    if [[ $# -gt 0 ]]; then
        case "$1" in
            config)
                SUBCOMMAND="$1"
                shift
                ;;
        esac
    fi

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f)
                if [[ $# -lt 2 ]]; then
                    echo -e "${RED}Error: -f requires an argument${NC}" >&2
                    exit 1
                fi
                shift
                CONFIG_FILE="$1"
                ;;
            --dry-run)
                DRY_RUN=true
                ;;
            --check)
                CONFIG_CHECK=true
                ;;
            -y|--yes)
                CONFIG_YES=true
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            -v|--version)
                echo "claude-compose v${VERSION}"
                exit 0
                ;;
            --)
                shift
                EXTRA_ARGS=("$@")
                break
                ;;
            *)
                # For config subcommand, treat positional arg as path
                if [[ "$SUBCOMMAND" == "config" && -z "$CONFIG_PATH" && "$1" != -* ]]; then
                    CONFIG_PATH="$1"
                else
                    echo -e "${RED}Unknown option: $1${NC}" >&2
                    usage >&2
                    exit 1
                fi
                ;;
        esac
        shift
    done

    # Default config file
    if [[ -z "$CONFIG_FILE" ]]; then
        CONFIG_FILE="claude-compose.json"
    fi

    # Validate flag combinations
    if [[ "$CONFIG_YES" == true && "$SUBCOMMAND" != "config" ]]; then
        echo -e "${RED}Error: -y/--yes can only be used with 'config'${NC}" >&2
        exit 1
    fi
    if [[ "$CONFIG_CHECK" == true && "$SUBCOMMAND" != "config" ]]; then
        echo -e "${RED}Error: --check can only be used with 'config'${NC}" >&2
        exit 1
    fi
}

# ── Require jq ───────────────────────────────────────────────────────
require_jq() {
    if ! command -v jq &>/dev/null; then
        echo -e "${RED}Error: jq is required but not installed.${NC}" >&2
        echo "  Install: brew install jq" >&2
        exit 1
    fi
}

require_claude() {
    if ! command -v claude &>/dev/null; then
        echo -e "${RED}Error: claude CLI not found in PATH.${NC}" >&2
        exit 1
    fi
}

# ── Validate prerequisites ───────────────────────────────────────────
validate() {
    require_jq

    # Check claude
    if ! command -v claude &>/dev/null; then
        echo -e "${RED}Error: claude CLI not found in PATH.${NC}" >&2
        exit 1
    fi

    # Check config file
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo -e "${YELLOW}Config not found: ${CONFIG_FILE}. Launching plain claude.${NC}" >&2
        claude "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}"
        exit 0
    fi

    # Validate JSON
    if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
        echo -e "${RED}Error: Invalid JSON in ${CONFIG_FILE}${NC}" >&2
        jq empty "$CONFIG_FILE" 2>&1 | head -5 >&2
        exit 1
    fi
}

# ── Expand ~ safely ─────────────────────────────────────────────────
expand_path() {
    local path="$1"
    echo "${path/#\~/$HOME}"
}

# ── Process a single project ────────────────────────────────────────
process_project() {
    local project_json="$1"
    local raw_path
    raw_path=$(echo "$project_json" | jq -r '.path')
    local project_path
    project_path=$(expand_path "$raw_path")

    # Check path exists
    if [[ ! -d "$project_path" ]]; then
        echo -e "${YELLOW}Warning: Project path not found, skipping: ${raw_path}${NC}" >&2
        return
    fi

    local short_name
    short_name=$(basename "$project_path")

    echo -e "${CYAN}Processing:${NC} ${short_name} (${project_path})" >&2

    # ── Files / CLAUDE.md ──
    local files claude_md
    files=$(echo "$project_json" | jq -r 'if has("files") then .files else true end')
    claude_md=$(echo "$project_json" | jq -r 'if has("claude_md") then .claude_md else true end')

    if [[ "$files" == "true" || "$claude_md" == "true" ]]; then
        CLAUDE_ARGS+=("--add-dir" "$project_path")
    fi

    if [[ "$claude_md" == "true" ]]; then
        NEED_CLAUDE_MD_ENV=true
    fi

    # ── MCP servers ──
    local mcp_file="$project_path/.mcp.json"
    if [[ -f "$mcp_file" ]]; then
        local mcp_include mcp_exclude mcp_rename
        mcp_include=$(echo "$project_json" | jq -c '.mcp.include // ["*"]')
        mcp_exclude=$(echo "$project_json" | jq -c '.mcp.exclude // []')
        mcp_rename=$(echo "$project_json" | jq -c '.mcp.rename // {}')

        while IFS= read -r name; do
            [[ -z "$name" ]] && continue
            if matches_filter "$name" "$mcp_include" "$mcp_exclude"; then
                local server_config final_name
                server_config=$(jq -c --arg n "$name" '.mcpServers[$n]' "$mcp_file")
                final_name=$(echo "$mcp_rename" | jq -r --arg n "$name" '.[$n] // $n')
                MERGED_MCP=$(echo "$MERGED_MCP" | jq --arg name "$final_name" --argjson config "$server_config" '. + {($name): $config}')
                if [[ "$final_name" != "$name" ]]; then
                    echo -e "  ${GREEN}+mcp:${NC} $name → $final_name" >&2
                else
                    echo -e "  ${GREEN}+mcp:${NC} $name" >&2
                fi
            fi
        done < <(jq -r '.mcpServers // {} | keys[]' "$mcp_file" 2>/dev/null || true)
    fi

    # ── Skills ──
    # --add-dir loads all skills from external project automatically.
    # Only copy skills when files=false (no --add-dir), otherwise skip to avoid duplicates.
    if [[ "$files" != "true" ]]; then
        local skills_dir="$project_path/.claude/skills"
        if [[ -d "$skills_dir" ]]; then
            local skills_include skills_exclude
            skills_include=$(echo "$project_json" | jq -c '.skills.include // ["*"]')
            skills_exclude=$(echo "$project_json" | jq -c '.skills.exclude // []')

            for skill_path in "$skills_dir"/*/; do
                [[ -d "$skill_path" ]] || continue
                local skill_name
                skill_name=$(basename "$skill_path")

                if matches_filter "$skill_name" "$skills_include" "$skills_exclude"; then
                    SKILLS_TO_COPY+=("${skill_path}|${skill_name}")
                    echo -e "  ${GREEN}+skill:${NC} $skill_name" >&2
                fi
            done
        fi
    else
        echo -e "  ${CYAN}skills:${NC} loaded via --add-dir (all)" >&2
    fi

    # ── Agents ──
    # --add-dir does NOT load agents — must always copy
    local agents_dir="$project_path/.claude/agents"
    if [[ -d "$agents_dir" ]]; then
        local agents_include agents_exclude agents_rename
        agents_include=$(echo "$project_json" | jq -c '.agents.include // ["*"]')
        agents_exclude=$(echo "$project_json" | jq -c '.agents.exclude // []')
        agents_rename=$(echo "$project_json" | jq -c '.agents.rename // {}')

        for agent_file in "$agents_dir"/*.md; do
            [[ -f "$agent_file" ]] || continue
            local agent_name
            agent_name=$(basename "$agent_file" .md)

            if matches_filter "$agent_name" "$agents_include" "$agents_exclude"; then
                local final_name
                final_name=$(echo "$agents_rename" | jq -r --arg n "$agent_name" '.[$n] // $n')
                AGENTS_TO_COPY+=("${agent_file}|${final_name}")
                if [[ "$final_name" != "$agent_name" ]]; then
                    echo -e "  ${GREEN}+agent:${NC} $agent_name → $final_name" >&2
                else
                    echo -e "  ${GREEN}+agent:${NC} $agent_name" >&2
                fi
            fi
        done
    fi

    # ── Permissions ──
    local settings_file="$project_path/.claude/settings.local.json"
    if [[ -f "$settings_file" ]]; then
        local perm_include perm_exclude
        perm_include=$(echo "$project_json" | jq -c '.permissions.include // ["*"]')
        perm_exclude=$(echo "$project_json" | jq -c '.permissions.exclude // []')

        while IFS= read -r perm; do
            [[ -z "$perm" ]] && continue
            if matches_filter "$perm" "$perm_include" "$perm_exclude"; then
                MERGED_PERMISSIONS=$(echo "$MERGED_PERMISSIONS" | jq --arg p "$perm" '. + [$p] | unique')
                echo -e "  ${GREEN}+perm:${NC} $perm" >&2
            fi
        done < <(jq -r '.permissions.allow // [] | .[]' "$settings_file" 2>/dev/null || true)
    fi
}

# ── Process a single preset ─────────────────────────────────────────
process_preset() {
    local preset_name="$1"

    # Cycle detection
    for processed in "${PROCESSED_PRESETS[@]+"${PROCESSED_PRESETS[@]}"}"; do
        if [[ "$processed" == "$preset_name" ]]; then
            echo -e "${YELLOW}Warning: Preset already processed, skipping: ${preset_name}${NC}" >&2
            return
        fi
    done
    PROCESSED_PRESETS+=("$preset_name")

    local preset_dir="$PRESETS_DIR/$preset_name"
    if [[ ! -d "$preset_dir" ]]; then
        echo -e "${RED}Error: Preset not found: ${preset_name} (~/.claude-compose/presets/${preset_name}/)${NC}" >&2
        exit 1
    fi

    echo -e "${CYAN}Processing preset:${NC} ${preset_name}" >&2

    # Read preset.json if present
    local preset_json="{}"
    if [[ -f "$preset_dir/preset.json" ]]; then
        preset_json=$(cat "$preset_dir/preset.json")
    fi

    # Build synthetic project_json: filter settings from preset.json + path
    # Default files=false (preset dir is not a real project), claude_md=true (load CLAUDE.md)
    local synthetic_project
    synthetic_project=$(echo "$preset_json" | jq -c --arg path "$preset_dir" '
        {path: $path}
        + (if has("mcp") then {mcp: .mcp} else {} end)
        + (if has("permissions") then {permissions: .permissions} else {} end)
        + (if has("agents") then {agents: .agents} else {} end)
        + (if has("skills") then {skills: .skills} else {} end)
        + {files: (if has("files") then .files else false end)}
        + {claude_md: (if has("claude_md") then .claude_md else true end)}
    ')

    process_project "$synthetic_project"

    # Recursively process nested presets
    local nested_presets
    nested_presets=$(echo "$preset_json" | jq -r '.presets // [] | .[]' 2>/dev/null || true)
    while IFS= read -r nested; do
        [[ -z "$nested" ]] && continue
        process_preset "$nested"
    done <<< "$nested_presets"

    # Process preset's projects
    local preset_project_count
    preset_project_count=$(echo "$preset_json" | jq '.projects // [] | length')
    if [[ "$preset_project_count" -gt 0 ]]; then
        for i in $(seq 0 $((preset_project_count - 1))); do
            local project_json
            project_json=$(echo "$preset_json" | jq -c ".projects[$i]")
            process_project "$project_json"
        done
    fi
}

# ── Process all presets from config ────────────────────────────────
process_all_presets() {
    local preset_names
    preset_names=$(jq -r '.presets // [] | .[]' "$CONFIG_FILE" 2>/dev/null || true)
    while IFS= read -r name; do
        [[ -z "$name" ]] && continue
        process_preset "$name"
    done <<< "$preset_names"
}

# ── Subcommand: config ───────────────────────────────────────────────
cmd_config() {
    require_jq

    # --check: validate config via dry-run pipeline
    if [[ "$CONFIG_CHECK" == true ]]; then
        if [[ ! -f "$CONFIG_FILE" ]]; then
            echo -e "${RED}Error: ${CONFIG_FILE} not found${NC}" >&2
            exit 1
        fi
        exec "$0" --dry-run -f "$CONFIG_FILE"
    fi

    # -y: quick create (pure bash, no Claude)
    if [[ "$CONFIG_YES" == true ]]; then
        if [[ -f "$CONFIG_FILE" ]]; then
            echo -e "${RED}Error: ${CONFIG_FILE} already exists. Run 'config' to edit.${NC}" >&2
            exit 1
        fi
        if [[ -z "$CONFIG_PATH" ]]; then
            echo -e "${RED}Error: Path required. Usage: claude-compose config -y <path>${NC}" >&2
            exit 1
        fi
        local tmp
        tmp=$(mktemp "${CONFIG_FILE}.XXXXXX")
        if ! jq -n --arg p "$CONFIG_PATH" '{projects: [{path: $p}]}' > "$tmp"; then
            rm -f "$tmp"
            echo -e "${RED}Error: Failed to create config${NC}" >&2
            exit 1
        fi
        mv "$tmp" "$CONFIG_FILE"
        echo -e "${GREEN}Created ${CONFIG_FILE}${NC}" >&2
        return
    fi

    # Interactive: launch Claude with compose-config skill
    require_claude

    # Validate existing config JSON (but don't block if file is absent — skill handles create mode)
    if [[ -f "$CONFIG_FILE" ]] && ! jq empty "$CONFIG_FILE" 2>/dev/null; then
        echo -e "${RED}Error: Invalid JSON in ${CONFIG_FILE}${NC}" >&2
        exit 1
    fi

    # Informational message about mode
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo -e "${CYAN}Config not found. Entering create mode.${NC}" >&2
    fi

    create_temp_session_dir
    trap cleanup_temp_session EXIT
    write_compose_skills "$CONFIG_FILE"

    cd "$SESSION_DIR"
    claude "/compose-config"
}

# ── Main ─────────────────────────────────────────────────────────────
main() {
    parse_args "$@"

    # Resolve CONFIG_FILE to absolute path (before any cd)
    local config_dir
    config_dir="$(dirname "$CONFIG_FILE")"
    if [[ -d "$config_dir" ]]; then
        CONFIG_FILE="$(cd "$config_dir" && pwd)/$(basename "$CONFIG_FILE")"
    fi

    # Dispatch subcommands before validate (they have own validation)
    case "$SUBCOMMAND" in
        config) cmd_config; return ;;
    esac

    validate

    echo -e "${BOLD}claude-compose${NC} v${VERSION}" >&2
    echo -e "Config: ${CONFIG_FILE}" >&2
    echo "" >&2

    # Read project and preset counts
    local project_count preset_count
    project_count=$(jq '.projects // [] | length' "$CONFIG_FILE")
    preset_count=$(jq '.presets // [] | length' "$CONFIG_FILE")

    if [[ "$project_count" -eq 0 && "$preset_count" -eq 0 ]]; then
        echo -e "${YELLOW}No projects or presets defined in config. Launching plain claude.${NC}" >&2
        claude "${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}"
        return
    fi

    # Process presets first (lower priority — projects override on conflicts)
    process_all_presets

    # Process each project
    if [[ "$project_count" -gt 0 ]]; then
        for i in $(seq 0 $((project_count - 1))); do
            local project_json
            project_json=$(jq -c ".projects[$i]" "$CONFIG_FILE")
            process_project "$project_json"
        done
    fi

    echo "" >&2

    # ── Build final command ──

    # Counts for display
    local mcp_server_count
    mcp_server_count=$(echo "$MERGED_MCP" | jq 'length')
    local perm_count
    perm_count=$(echo "$MERGED_PERMISSIONS" | jq 'length')

    # include_root: add original CWD as --add-dir
    local include_root
    include_root=$(jq -r '.include_root // true' "$CONFIG_FILE")
    if [[ "$include_root" == "true" ]]; then
        CLAUDE_ARGS+=("--add-dir" "$ORIGINAL_CWD")
        NEED_CLAUDE_MD_ENV=true
    fi

    # Extra args
    if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
        CLAUDE_ARGS+=("${EXTRA_ARGS[@]}")
    fi

    # ── Dry run ──
    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${BOLD}── Dry Run ──${NC}" >&2
        echo "" >&2

        if [[ "$preset_count" -gt 0 ]]; then
            echo -e "${CYAN}Active presets:${NC}" >&2
            jq -r '.presets // [] | .[]' "$CONFIG_FILE" | while read -r name; do
                echo "  - $name" >&2
            done
            echo "" >&2
        fi

        echo -e "${CYAN}Session directory:${NC}" >&2
        echo "  ~/.claude-compose/sessions/<config-hash>/" >&2
        echo "" >&2

        if [[ "$NEED_CLAUDE_MD_ENV" == true ]]; then
            echo -e "${CYAN}Environment:${NC}" >&2
            echo "  CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD=1" >&2
            echo "" >&2
        fi

        if [[ "$mcp_server_count" -gt 0 ]]; then
            echo -e "${CYAN}MCP servers → .mcp.json:${NC}" >&2
            echo "$MERGED_MCP" | jq -r 'keys[]' | while read -r name; do
                echo "  - $name" >&2
            done
            echo "" >&2
        fi

        if [[ ${#SKILLS_TO_COPY[@]} -gt 0 ]]; then
            echo -e "${CYAN}Skills → .claude/skills/:${NC}" >&2
            for entry in "${SKILLS_TO_COPY[@]}"; do
                local skill_name="${entry#*|}"
                echo "  - $skill_name" >&2
            done
            echo "" >&2
        fi

        if [[ ${#AGENTS_TO_COPY[@]} -gt 0 ]]; then
            echo -e "${CYAN}Agents → .claude/agents/:${NC}" >&2
            for entry in "${AGENTS_TO_COPY[@]}"; do
                local agent_name="${entry#*|}"
                echo "  - ${agent_name}.md" >&2
            done
            echo "" >&2
        fi

        echo -e "${CYAN}Settings → .claude/settings.local.json:${NC}" >&2
        if [[ "$perm_count" -gt 0 ]]; then
            echo "  Allow:" >&2
            echo "$MERGED_PERMISSIONS" | jq -r '.[]' | while read -r p; do
                echo "    - $p" >&2
            done
        fi
        echo "  Deny:" >&2
        echo "    - Edit(<session-dir>/**)" >&2
        echo "    - Write(<session-dir>/**)" >&2
        echo "" >&2

        echo -e "${CYAN}Directories (--add-dir):${NC}" >&2
        if [[ "$include_root" == "true" ]]; then
            echo "  - $ORIGINAL_CWD (root)" >&2
        fi
        for arg_idx in $(seq 0 $((${#CLAUDE_ARGS[@]} - 1))); do
            if [[ "${CLAUDE_ARGS[$arg_idx]}" == "--add-dir" && "$arg_idx" -lt $((${#CLAUDE_ARGS[@]} - 1)) ]]; then
                local dir_val="${CLAUDE_ARGS[$((arg_idx + 1))]}"
                if [[ "$dir_val" != "$ORIGINAL_CWD" ]]; then
                    echo "  - $dir_val" >&2
                fi
            fi
        done
        echo "" >&2

        echo -e "${CYAN}Compose skills (in-session):${NC}" >&2
        echo "  - /compose-config" >&2
        echo "" >&2

        echo -e "${GREEN}No mutations performed (dry run).${NC}" >&2
        return
    fi

    # Create stable session directory, check for conflicts, register early
    create_session_dir
    if ! check_session_state; then
        return 1
    fi
    register_session
    trap unregister_session EXIT

    # ── Apply mutations (write to session dir) ──

    # Write MCP config
    if [[ "$mcp_server_count" -gt 0 ]]; then
        echo "$MERGED_MCP" | jq --arg home "$HOME" \
            '{mcpServers: .} | walk(if type == "string" then gsub("\\$\\{HOME\\}"; $home) | gsub("^~(?=/|$)"; $home) else . end)' \
            > "$SESSION_DIR/.mcp.json"
    fi

    # Copy skills
    if [[ ${#SKILLS_TO_COPY[@]} -gt 0 ]]; then
        for entry in "${SKILLS_TO_COPY[@]}"; do
            local src="${entry%|*}"
            local skill_name="${entry#*|}"
            local dest="$SESSION_DIR/.claude/skills/${skill_name}"
            cp -R "$src" "$dest"
            echo -e "${GREEN}Copied skill:${NC} $skill_name" >&2
        done
    fi

    # Copy agents
    if [[ ${#AGENTS_TO_COPY[@]} -gt 0 ]]; then
        for entry in "${AGENTS_TO_COPY[@]}"; do
            local src="${entry%|*}"
            local agent_name="${entry#*|}"
            local dest="$SESSION_DIR/.claude/agents/${agent_name}.md"
            cp "$src" "$dest"
            echo -e "${GREEN}Copied agent:${NC} $agent_name" >&2
        done
    fi

    # Write compose management skills (available in-session)
    write_compose_skills "$CONFIG_FILE"

    # Write session settings (permissions + deny rules)
    write_session_settings

    # ── Launch ──
    echo -e "${BOLD}Launching claude...${NC}" >&2
    echo "" >&2

    if [[ "$NEED_CLAUDE_MD_ENV" == true ]]; then
        export CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD=1
    fi

    cd "$SESSION_DIR"
    claude "${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}"
}

main "$@"
